# local LLM models from ollama
# --- 向量模型配置 ---
MODEL_DIM=384
# --- Ollama 基础配置 ---
OLLAMA_URL=http://localhost:11434

# --- 1. VLM 模型配置 (用于图片索引) ---
# 建议选用 OCR 强、推理快的模型，如 minicpm-v:8b-2.6-q4_K_M
VLM_MODEL=minicpm-v:8b-2.6-q4_K_M
VLM_TEMP=0.1
VLM_REPEAT_PENALTY=1.1

# --- 2. RAG 助手模型配置 (用于日常对话) ---
# 建议选用逻辑强、显存占用适中的模型，如 gemma2:9b 或 qwen2.5:7b
RAG_MODEL=gemma2:9b
RAG_TEMP=0.7
RAG_REPEAT_PENALTY=1.2
RAG_K=10

# 数据库配置 database config
DB_DIR=.
DB_NAME=sift_local.db