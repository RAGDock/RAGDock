# Ollama connection settings
OLLAMA_URL=http://localhost:11434

# --- 1. VLM (Vision Language Model) Configuration ---
# Used for image indexing and OCR. Recommended: minicpm-v:8b-2.6-q4_K_M
VLM_MODEL=minicpm-v:8b-2.6-q4_K_M
VLM_TEMP=0.1
VLM_REPEAT_PENALTY=1.1

# --- 2. RAG (Chat) Model Configuration ---
# Used for answering questions based on your documents. Recommended: gemma2:9b or qwen2.5:7b
RAG_MODEL=qwen2.5:1.5b
RAG_TEMP=0.7
RAG_REPEAT_PENALTY=1.2
RAG_K=10

# --- 3. Local Embedding & Database Settings ---
MODEL_DIM=384
DB_DIR=.
DB_NAME=ragdock_local.db
