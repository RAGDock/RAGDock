# Ollama connection settings
OLLAMA_URL=http://localhost:11434

# --- 1. VLM (Vision Language Model) Configuration ---
# Used for image indexing and OCR (Ollama model)
VLM_MODEL=qwen2.5vl:3b
VLM_TEMP=0.1
VLM_REPEAT_PENALTY=1.1

# --- 2. RAG (Chat) Model Configuration ---
# Used for answering questions (Ollama model)
RAG_MODEL=qwen2.5:3b
RAG_TEMP=0.2
RAG_REPEAT_PENALTY=1.0
RAG_PRESENCE_PENALTY=1.2
RAG_NUM_CTX=4096
RAG_TOP_K=20
RAG_TOP_P=0.95
RAG_K=5

# --- 3. Local Embedding & Database Settings ---
MODEL_DIM=384
DB_DIR=.
DB_NAME=ragdock_local.db

# --- 4. Performance & Concurrency Settings ---
# App Language: 'zh' for Chinese, 'en' for English
APP_LANGUAGE=en

# Maximum concurrent VLM tasks.
VLM_CONCURRENCY=1